  m_Script: {fileID: 11500000, guid: 164520eb98c12c64c9224b845f24196a, type: 3}
  m_Name: BossDeath
  m_EditorClassIdentifier: 
  dialogData:
  - sprite: {fileID: 21300000, guid: 2cbd5203d64246c47aafa96c5c1cbe6d, type: 3}
    name: "\u7537\u5DEB"
    content: "\u867D\u7136\u4F60\u6253\u8D25\u4E86\u6211,\u4F46\u662F\u63A5\u4E0B\u6765\u7684\u51B0\u5C01\u57CE\u5821\u4F60\u4E0D\u53EF\u80FD\u7A7F\u8FC7\u7684,\u6C38\u8FDC\u7559\u5728\u8FD9\u91CC\u5427\u2026\u2026."
    audioclip: {fileID: 0}
  - sprite: {fileID: 21300000, guid: a78ac3bee6a7ada4080f892b5923298f, type: 3}
    name: "\u5C0F\u732B"
    content: "\u5DEB\u5E08\u7684\u5951\u7EA6\u89E3\u9664\u4E86\uFF0C\u4F46\u4F60\u7684\u65F6\u95F4\u4E0D\u591A\u4E86\u3002\u770B\u5230\u5317\u65B9\u90A3\u9053\u51B0\u971C\u75D5\u8FF9\u4E86\u5417\uFF1F"
    audioclip: {fileID: 0}
  - sprite: {fileID: 21300000, guid: 55c88303371b71847aebf489e6f9d16a, type: 3}
    name: "\u4E3B\u89D2"
    content: "\u90A3\u5C31\u662F...\u56DE\u5BB6\u7684\u8DEF\uFF1F"
    audioclip: {fileID: 0}
  - sprite: {fileID: 21300000, guid: a78ac3bee6a7ada4080f892b5923298f, type: 3}
    name: "\u5C0F\u732B"
    content: "\u662F\u7684,\u51B0\u5C01\u57CE\u5821\u91CC\u85CF\u7740\u80FD\u770B\u7A7F\u4E16\u754C\u771F\u76F8\u7684\u5B9D\u7269,\u627E\u5230\u5B83\u4F60\u624D\u80FD\u56DE\u5BB6\u3002\u4E0D\u8FC7\u2014\u2014\u90A3\u4E2A\u88AB\u79F0\u4F5C\u51B0\u96EA\u5973\u738B\u7684\u53EF\u6BD4\u5DEB\u5E08\u5371\u9669\u5341\u500D\u3002"
    audioclip: {fileID: 0}
  - sprite: {fileID: 21300000, guid: 55c88303371b71847aebf489e6f9d16a, type: 3}
    name: "\u4E3B\u89D2"
    content: "\u53CD\u6B63\u6211\u4E5F\u6CA1\u5F97\u9009\uFF0C\u5BF9\u5427\uFF1F"
    audioclip: {fileID: 0}
  - sprite: {fileID: 21300000, guid: a78ac3bee6a7ada4080f892b5923298f, type: 3}
    name: "\u5C0F\u732B"
    content: "\u611F\u8C22\u4F60\u6253\u8D25\u4E86\u574F\u5DEB\u5E08\uFF0C\u6211\u7ED9\u4F60\u65BD\u52A0\u4E00\u4E2A\u9B54\u6CD5,\u5E0C\u671B\u5728\u63A5\u4E0B\u6765\u80FD\u5E2E\u5230\u4F60\u3002\u8BB0\u4F4F\uFF0C\u57CE\u5821\u91CC\u7684\u51B0...\u4F1A\u51BB\u4F4F\u6240\u6709\u6E29\u6696\u7684\u8C0E\u8A00\u3002"
    audioclip: {fileID: 0}
