  dialogData:
  - sprite: {fileID: 21300000, guid: 13d56bbfec04b92418e025676bd5fd09, type: 3}
    name: "\u5C0F\u7EA2\u5E3D"
    content: "\u5916\u4E61\u4EBA\uFF1F\u4F60\u8EAB\u4E0A\u6709\u9B54\u5973\u7684\u8150\u81ED\u5473\u3002"
    audioclip: {fileID: 8300000, guid: febdd10b33094d0428f2cbc88458f012, type: 3}
  - sprite: {fileID: 21300000, guid: 55c88303371b71847aebf489e6f9d16a, type: 3}
    name: "\u4E3B\u89D2"
    content: "\u6211\u4E0D\u77E5\u9053\u4EC0\u4E48\u9B54\u5973\uFF01\u6211\u53EA\u662F...\u4ECE\u53E6\u4E00\u4E2A\u4E16\u754C\u6389\u8FDB\u6765\u7684\u3002"
    audioclip: {fileID: 8300000, guid: d9bfba5148e5cc64193065809417580f, type: 3}
  - sprite: {fileID: 21300000, guid: 13d56bbfec04b92418e025676bd5fd09, type: 3}
    name: "\u5C0F\u7EA2\u5E3D"
    content: "\u6211\u8981\u600E\u4E48\u76F8\u4FE1\u4F60\uFF1F\u6BCF\u4E2A\u88AB\u8BC5\u5492\u7684\u5BB6\u4F19\u90FD\u8FD9\u4E48\u8BF4\u3002\u8BC1\u660E\u7ED9\u6211\u770B\u3002"
    audioclip: {fileID: 8300000, guid: 10d49d03dc29188429aac78ec234149b, type: 3}
  - sprite: {fileID: 21300000, guid: 55c88303371b71847aebf489e6f9d16a, type: 3}
    name: "\u4E3B\u89D2"
    content: "\u7B49\u7B49...\u5982\u679C\u6211\u662F\u654C\u4EBA\uFF0C\u6211\u65E9\u8BE5\u52A8\u624B\u4E86\u2014\u2014"
    audioclip: {fileID: 8300000, guid: 10d49d03dc29188429aac78ec234149b, type: 3}
  - sprite: {fileID: 21300000, guid: 13d56bbfec04b92418e025676bd5fd09, type: 3}
    name: "\u5C0F\u7EA2\u5E3D"
    content: "\u5982\u679C\u4F60\u548C\u72FC\u4EBA\u662F\u4E00\u4F19\u7684\u2026
      \u6211\u4F1A\u4EB2\u624B\u4E3A\u4F60\u9001\u846C\u3002"
    audioclip: {fileID: 8300000, guid: 10d49d03dc29188429aac78ec234149b, type: 3}
  - sprite: {fileID: 21300000, guid: 55c88303371b71847aebf489e6f9d16a, type: 3}
    name: "\u4E3B\u89D2"
    content: "\u6240\u4EE5\u4F60\u6709\u79BB\u5F00\u8FD9\u8FB9\u7684\u65B9\u6CD5\u5417\uFF1F"
    audioclip: {fileID: 8300000, guid: 10d49d03dc29188429aac78ec234149b, type: 3}
  - sprite: {fileID: 21300000, guid: 13d56bbfec04b92418e025676bd5fd09, type: 3}
    name: "\u5C0F\u7EA2\u5E3D"
    content: "\"\u8DDF\u7D27\u3002\u82E5\u662F\u8E29\u4E2D\u6211\u8BBE\u7684\u6355\u517D\u5939...\"\uFF08\u8F6C\u8EAB\u9690\u5165\u8FF7\u96FE\uFF09\"\u6211\u4E0D\u4F1A\u6551\u4F60\u7B2C\u4E8C\u6B21\u3002\""
    audioclip: {fileID: 8300000, guid: 10d49d03dc29188429aac78ec234149b, type: 3}
